{
  "manifest_version": 3,
  "name": "Remove Multi Titles (YouTube)",
  "version": "2.0.0",
  "author": "Arzuparreta",
  "homepage_url": "https://github.com/Arzuparreta/remove-multi-titles-yt",
  "description": "Pins the first-seen title per video on YouTube (watch, Shorts, and lists) to reduce A/B title flicker.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["lib/browser-polyfill.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{a7b3c9d2-4e1f-4a8b-9c0d-1e2f3a4b5c6d}",
      "strict_min_version": "109.0"
    }
  }
}
